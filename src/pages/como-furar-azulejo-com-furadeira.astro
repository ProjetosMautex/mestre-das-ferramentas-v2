---
import Layout from '../layouts/Layout.astro';
import { ComoFurarAzulejoComFuradeira } from '../components/ComoFurarAzulejoComFuradeira';

const title = "Como furar azulejo com furadeira Modo prático e rápido";
const description = "Sem medo de rachaduras! Aprenda neste guia definitivo o passo-a-passo minucioso para furar revestimentos sensíveis como azulejos com tranquilidade e exatidão.";
