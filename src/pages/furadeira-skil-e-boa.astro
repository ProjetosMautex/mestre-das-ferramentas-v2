---
import Layout from '../layouts/Layout.astro';
import { FuradeiraSkilEBoa } from '../components/FuradeiraSkilEBoa';

const title = "Furadeira Skil é boa? Testei e conto se vale a pena";
const description = "Nos dias de hoje, escolher a ferramenta certa pode fazer toda a diferença em um projeto. A Furadeira Skil tem se destacado no mercado, prometendo desempenho e praticidade.";
---

