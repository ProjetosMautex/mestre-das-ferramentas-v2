---
import Layout from '../layouts/Layout.astro';
import { MelhorParafusadeira } from '../components/MelhorParafusadeira';

// Aqui você define o SEO da página
const title = "Melhor Parafusadeira de 2026: Top 11 Testadas e Aprovadas";
const description = "Compare as 11 melhores parafusadeiras de 2026 com testes reais, potência, bateria e custo-benefício. Veja qual vale mais a pena antes de comprar.";
---

<Layout title={title} description={description}>
  {/* O client:load é necessário para que os ícones do Lucide e interações funcionem */}
  <MelhorParafusadeira client:load />
</Layout>