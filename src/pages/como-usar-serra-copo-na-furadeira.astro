---
import Layout from '../layouts/Layout.astro';
import { ComoUsarSerraCopoNaFuradeira } from '../components/ComoUsarSerraCopoNaFuradeira';
---

<Layout 
  title="Como Usar Serra Copo na Furadeira: Guia Prático e Seguro"
