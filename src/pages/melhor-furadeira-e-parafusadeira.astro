---
import Layout from '../layouts/Layout.astro';
import { MelhorFuradeiraParafusadeira } from '../components/MelhorFuradeiraParafusadeira';

// SEO e Metadados da Página
const title = "Melhor Furadeira e Parafusadeira 2026: Guia de Compra Completo";
const description = "Descubra qual a melhor furadeira e parafusadeira de impacto em 2026. Analisamos os modelos da Bosch, Makita, DeWalt e WAP para uso profissional e doméstico.";
---

<Layout title={title} description={description}>
  {/* O 'client:load' garante que o componente seja hidratado no navegador, 
    permitindo que os ícones (Lucide) e funções interativas funcionem. 
  */}
  <MelhorFuradeiraParafusadeira client:load />
</Layout>